# --- RSVP email (Resend) ---
# Sign up at https://resend.com, create an API key, paste it here.
# In Vercel: Project Settings -> Environment Variables.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address. Until you verify your own domain in Resend you can use
# the shared sandbox sender below (it can only send to your own verified email):
#   RESEND_FROM="Semicentennial Bureau <onboarding@resend.dev>"
# Once your domain is verified, switch to something on-brand, e.g.:
#   RESEND_FROM="Semicentennial Bureau <bureau@yourdomain.com>"
RESEND_FROM="Semicentennial Bureau <onboarding@resend.dev>"

# Where the host notification email lands (your inbox).
HOST_EMAIL=you@example.com
